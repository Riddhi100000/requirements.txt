def get_current_user():
    """Get the currently logged-in user from session"""
    if "user_id" in session:
        conn = get_connection()
        user = conn.execute(
            "SELECT * FROM users WHERE id = ?",
            (session["user_id"],)
        ).fetchone()
        conn.close()
        return user
    return None


