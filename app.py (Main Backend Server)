@app.route("/api/sos", methods=["POST"])
def trigger_sos():
    """
    TRIGGER SOS ALERT
    This is the most important endpoint!
    When the SOS button is pressed, this:
    1. Saves the location
    2. Saves any audio recording
    3. Returns list of contacts to notify
    """
    user = get_current_user()
    if not user:
        return jsonify({"error": "Not logged in"}), 401

    data = request.get_json()
    latitude = data.get("latitude", 0)
    longitude = data.get("longitude", 0)
    address = data.get("address", "Location unavailable")

    conn = get_connection()

    # Save the alert to database
    conn.execute(
        "INSERT INTO alerts (user_id, latitude, longitude, address) VALUES (?, ?, ?, ?)",
        (session["user_id"], latitude, longitude, address)
    )
    conn.commit()

    # Get emergency contacts to notify
    contacts = conn.execute(
        "SELECT contact_name, contact_phone, relation FROM contacts WHERE user_id = ?",
        (session["user_id"],)
    ).fetchall()

    conn.close()

    # Build notification list
    notify_list = []
    for c in contacts:
        notify_list.append({
            "name": c["contact_name"],
            "phone": c["contact_phone"],
            "relation": c["relation"]
        })

    return jsonify({
        "success": True,
        "message": "SOS Alert Triggered! Emergency contacts notified.",
        "user_name": user["full_name"],
        "location": {"lat": latitude, "lng": longitude, "address": address},
        "contacts_notified": notify_list,
        "timestamp": datetime.datetime.now().isoformat()
    })


@app.route("/api/upload-audio", methods=["POST"])
def upload_audio():
    """
    Upload audio evidence recording.
    The browser records audio and sends it here.
    """
    user = get_current_user()
    if not user:
        return jsonify({"error": "Not logged in"}), 401

    if "audio" not in request.files:
        return jsonify({"error": "No audio file"}), 400

    audio_file = request.files["audio"]
    if audio_file.filename == "":
        return jsonify({"error": "No file selected"}), 400

    # Create a unique filename
    timestamp = datetime.datetime.now().strftime("%Y%m%d_%H%M%S")
    filename = f"evidence_user{session['user_id']}_{timestamp}.webm"
    filepath = os.path.join(app.config["UPLOAD_FOLDER"], filename)
    audio_file.save(filepath)

    # Update the latest alert with the audio file reference
    conn = get_connection()
    conn.execute(
        "UPDATE alerts SET audio_file = ? WHERE user_id = ? AND audio_file IS NULL",
        (filename, session["user_id"])
    )
    conn.commit()
    conn.close()

    return jsonify({
        "success": True,
        "message": "Audio evidence saved securely.",
        "filename": filename
    })


@app.route("/api/add-contact", methods=["POST"])
def add_contact():
    """Add a new emergency contact"""
    user = get_current_user()
    if not user:
        return jsonify({"error": "Not logged in"}), 401

    data = request.get_json()
    name = data.get("name")
    phone = data.get("phone")
    relation = data.get("relation")

    conn = get_connection()
    conn.execute(
        "INSERT INTO contacts (user_id, contact_name, contact_phone, relation) VALUES (?, ?, ?, ?)",
        (session["user_id"], name, phone, relation)
    )
    conn.commit()
    conn.close()

    return jsonify({"success": True, "message": "Contact added!"})


@app.route("/api/delete-contact/<int:contact_id>", methods=["DELETE"])
def delete_contact(contact_id):
    """Delete an emergency contact"""
    user = get_current_user()
    if not user:
        return jsonify({"error": "Not logged in"}), 401

    conn = get_connection()
    conn.execute(
        "DELETE FROM contacts WHERE id = ? AND user_id = ?",
        (contact_id, session["user_id"])
    )
    conn.commit()
    conn.close()

    return jsonify({"success": True, "message": "Contact deleted!"})


